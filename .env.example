PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/codemesh
JWT_SECRET=
RESEND_API_KEY=
APP_URL=https://codemesh.org
ALLOWED_ORIGINS=https://codemesh.org
ADMIN_EMAILS=barramee25038@gmail.com
# Terminal is ON by default. Set DISABLE_TERMINAL=true to turn it off.
# Legacy: ENABLE_TERMINAL=false also disables the terminal.
DISABLE_TERMINAL=false
# Optional: GitHub fine-grained or classic PAT for higher rate limits on File → Import from GitHub
GITHUB_TOKEN=
# Max simultaneous socket users per room (default 50, max 200)
MAX_USERS_PER_SESSION=50
