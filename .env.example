PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/codemesh
JWT_SECRET=
RESEND_API_KEY=
APP_URL=https://codemesh.org
ALLOWED_ORIGINS=https://codemesh.org
# Include subdomains if you use them: https://codemesh.org,https://www.codemesh.org,https://clash.codemesh.org,https://admin.codemesh.org
ADMIN_EMAILS=barramee25038@gmail.com
# Terminal is ON by default. Set DISABLE_TERMINAL=true to turn it off.
# Legacy: ENABLE_TERMINAL=false also disables the terminal.
DISABLE_TERMINAL=false
# Optional: GitHub fine-grained or classic PAT for higher rate limits on File → Import from GitHub
GITHUB_TOKEN=
# Max simultaneous socket users per room (default 50, max 200)
MAX_USERS_PER_SESSION=50

# Clash grader (Gemini 3 defaults). IDs are updated by Google; see https://ai.google.dev/gemini-api/docs/gemini-3
GEMINI_API_KEY=
# Gemini 3 Flash — generates the problem JSON on Create (e.g. gemini-3-flash-preview, or gemini-3.1-flash-lite-preview for volume).
GEMINI_MODEL_FLASH=gemini-3-flash-preview
# Gemini 3.1 Pro — reviews quality after Flash (e.g. gemini-3.1-pro-preview).
GEMINI_MODEL_PRO=gemini-3.1-pro-preview
# Legacy alias if GEMINI_MODEL_FLASH is unset:
# GEMINI_MODEL=gemini-3-flash-preview
# Optional override (default: https://generativelanguage.googleapis.com)
# GEMINI_API_BASE=
